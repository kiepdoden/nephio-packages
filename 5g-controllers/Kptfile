        	pipeline.run: exec: "docker": executable file not found in $PATH
        docker must be running to use this command
        To install docker, follow the instructions at https://docs.docker.com/get-docker/.
  renderStatus:
    mutationSteps:
      - image: ghcr.io/kptdev/krm-functions-catalog/apply-setters:v0.2
        exitCode: 1
    errorSummary: 'ghcr.io/kptdev/krm-functions-catalog/apply-setters:v0.2: exit code 1'
